APP_ENV=<prod|dev>

FORM_TYPE=<contact|sepa>

# --- Topbar-Links (optional) ---
# URLs in content/home/topbar-links.json können {{VAR_NAME}}-Platzhalter enthalten.
# Beispiel: "url": "{{APP_URL}}" wird durch den Wert dieser Variable ersetzt.
# APP_URL=https://app.example.com
# ADMIN_URL=https://admin.example.com

# --- Sections (alle aktiv wenn nicht gesetzt; auf false setzen zum Deaktivieren) ---
SECTION_HERO=true
SECTION_GALLERY=true
SECTION_STATS=true
SECTION_ABOUT=true
SECTION_CONTACT=true

PLACE=<ort>
SEPA_CREDITOR_NAME=<name des gläubigers>
SEPA_CREDITOR_ADRESS=<strasse + plz + ort>
SEPA_CREDITOR_ID=<gläubiger-id>

# --- Mailversand ---
# DEV (Mailpit lokal):
#   MAIL_HOST=127.0.0.1
#   MAIL_PORT=1025
#   MAIL_SECURE=
#   MAIL_USER=
#   MAIL_PASS=
#   MAIL_FROM=dev@example.local
#   MAIL_FROM_NAME=Dev
#   MAIL_TO=inbox@example.local
#
# PROD (SMTP):
MAIL_HOST=<smtp-server>
MAIL_PORT=<smtp-port>
MAIL_USER=<smtp-username>
MAIL_PASS=<smtp-password>
MAIL_FROM=<smtp-from-address>
MAIL_FROM_NAME=<smtp-from-name>
MAIL_TO=<recipient-email>
MAIL_SECURE=<tls|ssl>
