{
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/Helpers/escaper.php",
      "src/Helpers/Helpers.php",
      "src/Security/session.php",
      "src/Security/headers.php",
      "src/Security/csrf.php",
      "src/http/FormEndpoint.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.0",
    "ext-ctype": "*",
    "ext-curl": "*",
    "ext-filter": "*",
    "ext-hash": "*",
    "ext-iconv": "*",
    "ext-mbstring": "*",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^7.0",
    "tecnickcom/tcpdf": "^6.10",
    "erusev/parsedown": "^1.8"
  },
  "require-dev": {
    "ext-dom": "*",
    "ext-json": "*",
    "ext-libxml": "*",
    "ext-phar": "*",
    "ext-tokenizer": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "test": "phpunit --exclude-group integration",
    "test-js": "npm test",
    "test-integration": "phpunit --testsuite integration"
  }
}
